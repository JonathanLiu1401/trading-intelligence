<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jonathan.trading-intelligence.unified-dashboard</string>

  <key>Comment</key>
  <string>Trading Intelligence unified FastAPI dashboard</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/jonathan/trading-intelligence/launchd/run_unified_dashboard.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/jonathan/trading-intelligence/digital-intern</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/jonathan</string>
    <key>PYTHONPATH</key>
    <string>.</string>
    <key>DASHBOARD_PORT</key>
    <string>8765</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardInPath</key>
  <string>/dev/null</string>

  <key>StandardOutPath</key>
  <string>/Users/jonathan/trading-intelligence/logs/unified-dashboard.launchd.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/jonathan/trading-intelligence/logs/unified-dashboard.launchd.err.log</string>
</dict>
</plist>
